{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openresume.local/schemas/resume_modules.schema.json",
  "title": "Resume modules",
  "description": "Structured resume content consumed by deterministic resume templates.",
  "type": "object",
  "required": ["template_id", "language", "header", "modules"],
  "additionalProperties": true,
  "properties": {
    "template_id": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "default": "zh-CN"
    },
    "header": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "website": {
          "type": "string"
        },
        "photo": {
          "type": "string"
        }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["module_id", "title", "items"],
        "additionalProperties": true,
        "properties": {
          "module_id": {
            "type": "string",
            "enum": [
              "summary",
              "education",
              "experience",
              "projects",
              "publications",
              "awards",
              "skills",
              "certifications"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "quality_constraints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "page_limit": {
          "type": "integer",
          "minimum": 1
        },
        "max_experience_bullets": {
          "type": "integer",
          "minimum": 1
        },
        "max_project_bullets": {
          "type": "integer",
          "minimum": 1
        },
        "max_awards": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
