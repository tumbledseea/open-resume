{
  "template_id": "dark_sidebar",
  "name": "深色左边栏对比式中文简历",
  "description": "深色左边栏（金色点缀）+ 浅色右侧内容区，双栏强对比，适合创意/设计岗位。",
  "source_pdf": "examples/template6.pdf",
  "renderer": "../../scripts/renderers/render_dark_sidebar.py",
  "document_class": "latex/dark_sidebar.cls",
  "entrypoint_template": "latex/main.tex.j2",
  "page": { "size": "a4", "orientation": "portrait" },
  "required_modules": ["education", "experience", "projects", "awards"],
  "optional_modules": ["summary", "skills", "certifications"],
  "module_slots": {
    "education": "School, badges, degree, major, time, location, details.",
    "experience": "Organization, role, time, project, labeled bullets.",
    "projects": "Project name, role, time, bullets.",
    "awards": "Award name + time right-aligned."
  }
}
