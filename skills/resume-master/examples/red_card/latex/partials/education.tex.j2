\TemplateSectionTitle{ {{ module.title }} }
\begin{TemplateCard}
{% for item in module["items"] %}
\EntryHeader{ {{ item.school }}{% for badge in item.badges %}\Badge{ {{ badge }} }{% endfor %} }{ {{ item.time }} }
\EntryRole{ {{ item.major }}{% if item.degree %} \quad {{ item.degree }}{% endif %}{% if item.college %} \quad {{ item.college }}{% endif %}{% if item.study_type %} \quad {{ item.study_type }}{% endif %} }{ {{ item.location }} }
{% if item.details %}
\begin{itemize}
{% for detail in item.details %}
  \item {{ detail }}
{% endfor %}
\end{itemize}
{% endif %}
{% if not loop.last %}\vspace{0.18em}{% endif %}
{% endfor %}
\end{TemplateCard}
