\TemplateSectionTitle{ {{ module.title }} }
\begin{TemplateCard}
{% for item in module["items"] %}
\EntryHeader{ {{ item.school }}{% for badge in item.badges %}\Badge{ {{ badge }} }{% endfor %} }{ {{ item.time }} }
\EntrySubheader{ {{ item.major }} \quad {{ item.degree }} \quad {{ item.college }} \quad {{ item.study_type }} }{ {{ item.location }} }
{% if item.details %}
\begin{itemize}
{% for detail in item.details %}
  \item {{ detail }}
{% endfor %}
\end{itemize}
{% endif %}
{% if not loop.last %}\vspace{0.18em}{% endif %}
{% endfor %}
\end{TemplateCard}
