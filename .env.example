# =============================================================================
# OpenResume .env 配置
# 复制此文件为 .env 并填入你的真实密钥。.env 不会被 git 追踪。
#   cp .env.example .env
# =============================================================================

# ── LLM API（必填）── 大模型推理 ────────────────────────────────────────────
# 任一 OpenAI-compatible API：SiliconFlow / DeepSeek / OpenAI / 其他。
# 默认用硅基流动 SiliconFlow（聚合 DeepSeek/Qwen/GLM，注册送额度、国内访问快）。
# 模型列表：https://cloud.siliconflow.cn/me/models
# 换成 OpenAI 时：BASE_URL=https://api.openai.com/v1  MODEL_NAME=gpt-4o
API_KEY = sk-your-api-key-here
BASE_URL = https://api.siliconflow.cn/v1
MODEL_NAME = deepseek-ai/DeepSeek-V4-Flash

# ── 岗位爬取（可选）── 网页抓取 ─────────────────────────────────────────────
# Firecrawl API key。自带无头浏览器，能抓 JS 动态渲染的招聘页（字节跳动、
# 腾讯、阿里等），并自动清洗成干净 markdown——这是拿到真实完整 JD 的关键。
# 不填则回退到 DuckDuckGo 搜索 + urllib（能力受限，拿不到动态渲染内容）。
# 获取免费额度：https://www.firecrawl.dev/
FIRECRAWL_API_KEY =

# ── BOSS 直聘（可选，默认关闭）─────────────────────────────────────────────
# 仅在 pipeline --enable-boss 时生效。
# 获取方式：浏览器登录 BOSS 直聘后用 Cookie-Editor 插件导出 header string。
BOSS_COOKIES =
